# Local fd Docker Compose environment template.
# Copy to .env for local development overrides.
# Never commit real secrets. The real .env file is gitignored.

# Protected endpoints fail closed when unset. Set a local random value to test
# /v1/embeddings, /v1/cache/*, /metrics, and other protected routes.
FD_API_KEY=

# Current production/default runtime is TEI with deepvk/USER-bge-m3.
MODEL_ID=deepvk/USER-bge-m3
TEI_URL=http://tei:80

# Redis inside Docker Compose.
REDIS_HOST=redis:6379
REDIS_QUEUE=embed:queue
CACHE_PREFIX=embed:cache:
REDIS_POOL_SIZE=50
REDIS_CACHE_TTL=
REDIS_CACHE_NO_EXPIRE=

# Correctness-affecting cache namespace knobs. Change these when comparing
# different backends/models/tokenizers/chunking, or deliberately flush Redis.
EMBEDDING_CACHE_VERSION=
EMBEDDING_MODEL_ID=
EMBEDDING_MODEL_REVISION=
EMBEDDING_TOKENIZER_VERSION=
EMBEDDING_CHUNKING_VERSION=

# Runtime controls.
FD_MAX_IN_FLIGHT=0
FD_CORS_ORIGINS=
FD_RATE_LIMIT_ENABLED=
FD_TRACES_ENABLED=
LOG_LEVEL=info
GIN_MODE=release
