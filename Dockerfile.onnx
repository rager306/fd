# Dedicated opt-in ONNX image for local packaging validation.
# Build context is generated by tools/build_onnx_image.sh under .gsd/runtime/.
# This image is not the default TEI production image.

FROM golang:1.25-bookworm AS builder
RUN apt-get update \
    && apt-get install -y --no-install-recommends ca-certificates git \
    && rm -rf /var/lib/apt/lists/*
WORKDIR /src/api

COPY api/go.mod api/go.sum ./
RUN go mod download

COPY api/ ./
COPY .gsd/runtime/tokenizers/linux-amd64/libtokenizers.a /artifacts/tokenizers/linux-amd64/libtokenizers.a

ARG VERSION=dev
ARG BUILD_HASH=unknown
ARG BUILD_DATE=unknown

RUN CGO_ENABLED=1 GOOS=linux \
    CGO_LDFLAGS="-L/artifacts/tokenizers/linux-amd64" \
    go build -tags "onnx hf_tokenizers" \
    -ldflags="-s -w -X main.Version=${VERSION} -X main.BuildHash=${BUILD_HASH} -X main.BuildDate=${BUILD_DATE}" \
    -trimpath \
    -o /out/api .

FROM debian:stable-slim
RUN apt-get update \
    && apt-get install -y --no-install-recommends ca-certificates curl \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app
COPY --from=builder /out/api /api
COPY docs/onnx-artifacts/ /app/docs/onnx-artifacts/
COPY .gsd/runtime/onnx/m010-s03/user-bge-m3-dense.onnx /app/.gsd/runtime/onnx/m010-s03/user-bge-m3-dense.onnx
COPY tokenizer/tokenizer.json /app/tokenizer/tokenizer.json
COPY onnxruntime/libonnxruntime.so.1.26.0 /opt/onnxruntime/libonnxruntime.so.1.26.0

ENV GIN_MODE=release \
    EMBEDDING_BACKEND=onnx \
    ONNX_ARTIFACT_MANIFEST=/app/docs/onnx-artifacts/user-bge-m3-dense-fp32.json \
    ONNX_RUNTIME_LIBRARY=/opt/onnxruntime/libonnxruntime.so.1.26.0 \
    ONNX_TOKENIZER_PATH=/app/tokenizer/tokenizer.json \
    ONNX_MAX_SEQUENCE_LENGTH=1024

ENTRYPOINT ["/api"]
